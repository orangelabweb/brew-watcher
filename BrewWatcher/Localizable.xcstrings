          "stringUnit" : {
            "state" : "translated",
            "value" : "Kollar..."
          }
        }
      }
    },
    "Clicking the button below opens Terminal with the official install script. You'll need to enter your password." : {
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "När du klickar på knappen nedan öppnas Terminal med det officiella installationsskriptet. Du kommer att behöva ange ditt lösenord."
          }
        }
      }
    },
    "Couldn't open Terminal: %@" : {
      "localizations" : {
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kunde inte öppna Terminal: %@"
